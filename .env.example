####################################################################
# AWS Summit Japan 2026 — オンデマンド検索アプリ サンプル環境変数
#
# 使い方: 本ファイルをコピーして `.env` にリネームし、必要な値を埋める。
#   cp .env.example .env
#   $EDITOR .env
#
# アプリの sidecar (app/server/sidecar.mjs) と要約スクリプト (scripts/summarize.mjs)
# はこの .env を自動的に読み込む。 シェル環境変数で設定済みの値はそちらが優先される。
####################################################################

# ---- LLM バックエンドの選択 (sidecar のみ参照) ----
# 'api'   = Anthropic API キーを使って Messages API を直接呼ぶ (公開リポの標準パス)。
#           ANTHROPIC_API_KEY を必ず設定すること。
# 'agent' = ローカルの Claude Code (要 `claude /login`) のサブスクで動作。
#           Claude Code をインストール済みの利用者向けのオプションパス。
LLM_BACKEND=api

# ---- ANTHROPIC_API_KEY (要約生成 / LLM_BACKEND=api の sidecar に必須) ----
# https://console.anthropic.com/settings/keys から取得。 sk-ant- で始まる文字列。
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- モデル (任意) ----
# 既定: claude-sonnet-4-6
# その他: claude-opus-4-8, claude-opus-4-7, claude-haiku-4-5
# ASK_MODEL=claude-sonnet-4-6           # sidecar (Ask AI) のモデル
# ANTHROPIC_MODEL=claude-sonnet-4-6     # scripts/summarize.mjs の要約モデル

# ---- 要約スクリプトのチューニング (任意) ----
# SUMMARIZE_CONCURRENCY=4               # 並列度。 レート制限が緩いなら上げる
# SUMMARIZE_MAX_RETRIES=4               # 429/5xx 時の最大リトライ回数

# ---- sidecar の listen ポート (任意、既定 3001) ----
# SIDECAR_PORT=3001

# ---- CORS allowlist (任意、既定 http://localhost:5173,http://127.0.0.1:5173) ----
# Vite dev server 以外のオリジンを許可したい場合のみカンマ区切りで指定。
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- bookmarks/lists/chats を保存する SQLite DB のパス (任意) ----
# 既定: <repo-root>/data/bookmarks.db
# BOOKMARKS_DB=./data/bookmarks.db
